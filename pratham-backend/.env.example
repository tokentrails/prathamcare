APP_ENV=dev
AWS_REGION=ap-south-1

AURORA_DSN_SECRET_ARN=
AURORA_DSN=
RDS_PROXY_ENDPOINT=

DDB_TABLE_SESSIONS=prathamcare-sessions
DDB_TABLE_OFFLINE_QUEUE=prathamcare-offline-queue
DDB_TABLE_TASK_LOGS=prathamcare-task-logs
DDB_TABLE_SCHEDULES=prathamcare-schedules
DDB_SCHEDULE_PK=physician_id
DDB_SCHEDULE_SK=schedule_slot

HEALTHLAKE_ENABLED=true
HEALTHLAKE_FHIR_ENDPOINT=

S3_BUCKET_DOCUMENTS=prathamcare-medical-documents
S3_BUCKET_VOICE=prathamcare-voice-recordings
TRANSCRIBE_LANGUAGE_OPTIONS=en-IN,kn-IN

OPENSEARCH_ENDPOINT=

COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Optional AI diagnostics (disable in normal production use)
AI_DEBUG_LOGS_ENABLED=false
AI_DEBUG_LOG_MAX_CHARS=4000
